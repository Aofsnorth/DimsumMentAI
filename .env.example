# API keys for DimsumMentAI.
# Copy this file to `.env` (in the project root, next to configs/) and fill in
# your keys. `.env` is gitignored — never commit real keys.
#
# The key used by the bot depends on the `ai.provider` setting in configs/bot.yaml:
#   nvidia            -> NVIDIA_API_KEY
#   minimax           -> MINIMAX_API_KEY
#   opengateway       -> OPENAI_API_KEY
#   openai_compatible -> OPENAI_API_KEY
#
# The .env file is auto-loaded on startup by the config loader (godotenv).
# Existing shell env vars always take precedence over .env values.

NVIDIA_API_KEY=
MINIMAX_API_KEY=
OPENAI_API_KEY=
