#!/usr/bin/env bash
# =============================================================================
# Pre-commit Hook — Feedforward Harness Gate
# =============================================================================
# Runs fast, deterministic checks before a commit is created. This is the
# earliest feedback point in the change lifecycle ("keep quality left").
#
# Install:  make install-hooks
# Or:       cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#
# Skip:     git commit --no-verify  (use sparingly)
# =============================================================================

set -euo pipefail

# Colors
RED='\033[31m'
GREEN='\033[32m'
CYAN='\033[36m'
YELLOW='\033[33m'
NC='\033[0m'

# Only run on commits that include Go files.
GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
if [ -z "$GO_FILES" ]; then
    exit 0
fi

echo -e "${CYAN}→ Running pre-commit harness checks...${NC}"

FAILED=0

# --- 1. gofmt check (computational guide) ---
UNFORMATTED=$(gofmt -l $GO_FILES 2>/dev/null || true)
if [ -n "$UNFORMATTED" ]; then
    echo -e "${RED}✗ gofmt: files need formatting:${NC}"
    echo "$UNFORMATTED"
    echo -e "${YELLOW}  Fix: gofmt -w $GO_FILES${NC}"
    FAILED=1
fi

# --- 2. go vet (computational sensor) ---
if ! go vet ./... 2>/dev/null; then
    echo -e "${RED}✗ go vet: issues found${NC}"
    FAILED=1
fi

# --- 3. Build check (computational sensor) ---
if ! go build ./cmd/... ./internal/... 2>/dev/null; then
    echo -e "${RED}✗ go build: compilation failed${NC}"
    FAILED=1
fi

# --- 4. Fast unit tests (computational sensor) ---
# Only run tests for packages that changed to keep the hook fast.
CHANGED_PKGS=""
for f in $GO_FILES; do
    dir=$(dirname "$f")
    pkg=$(cd "$dir" && go list . 2>/dev/null || true)
    if [ -n "$pkg" ]; then
        CHANGED_PKGS="$CHANGED_PKGS $pkg"
    fi
done
if [ -n "$CHANGED_PKGS" ]; then
    if ! go test -count=1 -short $CHANGED_PKGS 2>/dev/null; then
        echo -e "${RED}✗ go test: tests failed for changed packages${NC}"
        FAILED=1
    fi
fi

# --- Result ---
if [ $FAILED -ne 0 ]; then
    echo ""
    echo -e "${RED}✗ Pre-commit harness FAILED.${NC}"
    echo -e "${YELLOW}  Fix the issues above or use 'git commit --no-verify' to skip.${NC}"
    exit 1
fi

echo -e "${GREEN}✓ Pre-commit harness passed.${NC}"
exit 0
